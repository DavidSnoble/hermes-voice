# Deepgram — Speech-to-Text
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Cartesia — Text-to-Speech
CARTESIA_API_KEY=your_cartesia_api_key_here

# LLM Provider (OpenRouter recommended for cost/variety)
LLM_API_KEY=your_openrouter_or_openai_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# Hermes Gateway API Server
# Hermes must be configured with: API_SERVER_ENABLED=true, API_SERVER_KEY=xxx
HERMES_API_KEY=your_hermes_api_server_key_here
HERMES_API_URL=http://127.0.0.1:8642

# Voice Server
VOICE_PORT=9120
VOICE_HOST=0.0.0.0

# Optional: custom Hermes home directory
# HERMES_HOME=/root/.hermes

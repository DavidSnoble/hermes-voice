# Deepgram — Speech-to-Text
DEEPGRAM_API_KEY=your_d...here

# Cartesia — Text-to-Speech
CARTESIA_API_KEY=your_c...here

# Hermes Gateway — LLM + Task Delegation
# The voice app uses Hermes' built-in /v1/chat/completions endpoint.
# Hermes must be configured with: API_SERVER_ENABLED=true, API_SERVER_KEY=xxx
HERMES_API_KEY=your_h...here
HERMES_API_URL=http://127.0.0.1:8642

# Voice Server
VOICE_PORT=9120
VOICE_HOST=0.0.0.0

# Optional: custom Hermes home directory
# HERMES_HOME=/root/.hermes
